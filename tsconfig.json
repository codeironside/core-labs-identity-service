{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@core/*": ["CORE/*"],
      "@api/*": ["API/*"],
      "@app/*": ["APP/*"]
    }
  },
  "include": ["APP/**/*.ts", "API/**/*.ts", "CORE/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
